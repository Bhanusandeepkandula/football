{
  "expo": {
    "name": "Match Center",
    "slug": "football-world-cup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-sryln.png",
    "scheme": "football-world-cup",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "bundleIdentifier": "com.sandeep.worldcup2026",
      "appleTeamId": "Q7T5Z274SZ",
      "supportsTablet": false,
      "infoPlist": {
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "backgroundColor": "#0A0E1A"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@bacons/apple-targets"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
