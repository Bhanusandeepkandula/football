{
  "name": "@matchcenter/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MatchCenter API — ESPN football proxy (REST + SSE + WebSocket) and APNs / Live-Activity push backend.",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@parse/node-apn": "^6.0.1",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "ws": "^8.18.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "tsx": "catalog:",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8"
  }
}
