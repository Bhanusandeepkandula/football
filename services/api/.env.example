# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# Shared secret the app sends as `Authorization: Bearer <API_TOKEN>` on the push
# endpoints. Optional in dev (auth DISABLED when unset); REQUIRED in production.
API_TOKEN=

# ── ESPN upstream (override only if ESPN moves hosts) ────────────────────────
# ESPN_SITE_API=https://site.api.espn.com/apis/site/v2/sports/soccer
# ESPN_CORE_API=https://sports.core.api.espn.com/v2/sports/soccer/leagues
# ESPN_WEB_API=https://site.web.api.espn.com/apis/v2/sports/soccer
# ESPN_FASTCAST_HANDSHAKE=https://fastcast.semfs.engsvc.go.com/public/websockethost

# Live REST-fallback / snapshot poll cadence (ms).
POLL_MS=15000

# ── APNs / Live Activity push (required ONLY to enable the push worker) ───────
# Needs a PAID Apple Developer account. Leave the first three blank to run the
# service in proxy-only mode (REST + SSE + WS, no background push).
#
# Paste the PEM contents of your AuthKey_XXXX.p8 (including the BEGIN/END lines).
# In a systemd EnvironmentFile use a single line with literal \n between lines,
# or point APNS_KEY_P8 at the file and read it in the push worker.
APNS_KEY_P8=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.sandeep.worldcup2026
# sandbox = dev builds / Xcode; production = TestFlight / App Store.
APNS_ENV=sandbox
